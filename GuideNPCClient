-- Fungsi untuk mengisi tombol sesuai station
local function buildMenu(stationName)
	-- Hapus tombol lama
	for _, child in ipairs(buttonFrame:GetChildren()) do
		if not child:IsA("UIListLayout") then
			child:Destroy()
		end
	end

	local options = STATION_OPTIONS[stationName] or {}

	for _, opt in ipairs(options) do
		local btn = Instance.new("TextButton")
		btn.Size             = UDim2.new(1, 0, 0, 46)
		btn.BackgroundColor3 = opt.color
		btn.TextColor3       = Color3.fromRGB(255, 255, 255)
		btn.Text             = opt.label
		btn.TextSize         = 13
		btn.Font             = Enum.Font.GothamBold
		btn.BorderSizePixel  = 0
		btn.ZIndex           = 11
		btn.Parent           = buttonFrame
		addCorner(btn, 8)

		btn.MouseEnter:Connect(function()
			btn.BackgroundColor3 = opt.color:Lerp(Color3.fromRGB(255, 255, 255), 0.15)
		end)
		btn.MouseLeave:Connect(function()
			btn.BackgroundColor3 = opt.color
		end)
		btn.MouseButton1Click:Connect(function()
			menuFrame.Visible = false
			guideCommand:FireServer("Start", opt.key)
		end)
	end

	-- Sesuaikan tinggi frame otomatis
	local btnCount   = #options
	local frameH     = 50 + 30 + (btnCount * 54) + 50  -- title + sub + tombol + batal
	menuFrame.Size     = UDim2.new(0, 300, 0, frameH)
	menuFrame.Position = UDim2.new(0.5, -150, 0.5, -frameH / 2)
end

