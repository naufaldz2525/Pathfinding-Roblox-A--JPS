-- ========== FUNGSI NOTIFIKASI ==========
local notifThread = nil
local function showNotif(title, subtitle, color, duration)
	color    = color    or Color3.fromRGB(255, 200, 50)
	duration = duration or 4
	mainLabel.Text       = title
	subLabel.Text        = subtitle or ""
	iconLabel.TextColor3 = color
	notifFrame.BackgroundTransparency = 0.15
	notifFrame.Visible   = true

	if notifThread then task.cancel(notifThread) end
	notifThread = task.delay(duration, function()
		local tw = TweenService:Create(notifFrame,
			TweenInfo.new(0.5, Enum.EasingStyle.Quad),
			{ BackgroundTransparency = 1 }
		)
		tw:Play()
		tw.Completed:Wait()
		notifFrame.Visible = false
	end)
end

-- ========== TERIMA EVENT DARI SERVER ==========
guideEvent.OnClientEvent:Connect(function(eventType, data, extra, destLabel)

	if eventType == "OpenMenu" then
		-- data = nama station (GuideStation_Basecamp / Lembah / Puncak)
		buildMenu(data)
		menuFrame.Visible = true

	elseif eventType == "Status" then
		showNotif("Pemandu Jalan", tostring(data), Color3.fromRGB(255, 200, 50), 3)

	elseif eventType == "Error" then
		showNotif("⚠ Pemandu", tostring(data), Color3.fromRGB(255, 80, 80), 4)
		stopBtn.Visible = false

	elseif eventType == "Started" then
		local algoName = data == "AStar" and "A*" or "JPS"
		local tujuan   = destLabel or ""
		showNotif(
			"🧭 Pemandu Aktif!",
			tujuan .. " · " .. algoName .. " · " .. tostring(extra) .. " langkah",
			Color3.fromRGB(50, 220, 120),
			6
		)
		stopBtn.Visible = true

	elseif eventType == "Arrived" then
		showNotif("✅ Sampai!", "Kamu telah tiba di: " .. tostring(data), Color3.fromRGB(50, 220, 120), 5)
		stopBtn.Visible = false
	end
end)
