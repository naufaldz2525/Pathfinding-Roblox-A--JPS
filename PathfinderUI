local function makeResultBlock(label, color, yPos)
	local bg = Instance.new("Frame")
	bg.Size             = UDim2.new(1, -20, 0, 110)
	bg.Position         = UDim2.new(0, 10, 0, yPos)
	bg.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
	bg.BorderSizePixel  = 0
	bg.Parent           = resFrame
	addCorner(bg)

	local lbl = Instance.new("TextLabel")
	lbl.Size               = UDim2.new(1, -10, 0, 24)
	lbl.Position           = UDim2.new(0, 8, 0, 4)
	lbl.BackgroundTransparency = 1
	lbl.TextColor3         = color
	lbl.Text               = "= " .. label
	lbl.TextSize           = 13
	lbl.Font               = Enum.Font.GothamBold
	lbl.TextXAlignment     = Enum.TextXAlignment.Left
	lbl.Parent             = bg

	local info = Instance.new("TextLabel")
	info.Size               = UDim2.new(1, -10, 0, 76)
	info.Position           = UDim2.new(0, 8, 0, 28)
	info.BackgroundTransparency = 1
	info.TextColor3         = Color3.fromRGB(200, 200, 200)
	-- MODIFIKASI: default text tanpa Memori, tambah Dieksplorasi
	info.Text               = "Waktu        : -\nPanjang      : -\nDieksplorasi : -"
	info.TextSize           = 12
	info.Font               = Enum.Font.Code
	info.TextXAlignment     = Enum.TextXAlignment.Left
	info.TextYAlignment     = Enum.TextYAlignment.Top
	info.Parent             = bg

	return info
end

