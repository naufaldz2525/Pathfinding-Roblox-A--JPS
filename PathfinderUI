-- ========== TERIMA HASIL DARI SERVER ==========
-- MODIFIKASI: Parameter ke-4 sekarang nodesExplored (bukan memUsed)
resultEvent.OnClientEvent:Connect(function(algo, execTime, pathLength, nodesExplored, scenarioLabel)

	if algo == "Ready" then
		statusLabel.Text       = "Status: Siap!"
		statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
		return
	end

	if algo == "Reset" then
		astarInfo.Text   = "Waktu        : -\nPanjang      : -\nDieksplorasi : -"
		jpsInfo.Text     = "Waktu        : -\nPanjang      : -\nDieksplorasi : -"
		resFrame.Visible = false
		statusLabel.Text       = "Status: Memuat ulang grid..."
		statusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
		gridVisible      = false
		pathAstarVisible = true
		pathJPSVisible   = true
		updateGridToggleUI()
		updatePathAstarUI()
		updatePathJPSUI()
		return
	end

	if algo == "AStar_Failed" or algo == "JPS_Failed" then
		statusLabel.Text       = "Status: Jalur tidak ditemukan!"
		statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
		return
	end

	if algo == "AStar" or algo == "JPS" then
		if panelOpen then resFrame.Visible = true end
		statusLabel.Text       = "Status: Selesai!"
		statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)

		if scenarioLabel and scenarioLabel ~= "" then
			resScenarLabel.Text = "Titik: " .. tostring(scenarioLabel)
		else
			resScenarLabel.Text = "Titik: Default"
		end

		-- MODIFIKASI: Format baru tanpa Memori, tampilkan Dieksplorasi
		local text = string.format(
			"Waktu        : %.4f ms\nPanjang      : %d node\nDieksplorasi : %d node",
			execTime or 0, pathLength or 0, nodesExplored or 0
		)

		if algo == "AStar" then
			astarInfo.Text = text
		else
			jpsInfo.Text = text
		end
	end
end)
