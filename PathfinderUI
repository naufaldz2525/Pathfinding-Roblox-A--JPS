local function updateScenarioUI()
	for i, btn in ipairs(scenarioButtons) do
		if selectedScenario == scenKeys[i] then
			btn.BackgroundColor3 = COLOR_SKEN_ACTIVE
			btn.Text = "✔ " .. scenKeys[i]
		else
			btn.BackgroundColor3 = COLOR_SKEN_INACTIVE
			btn.Text = scenKeys[i]
		end
	end
	if selectedScenario == nil then
		defaultBtn.BackgroundColor3 = COLOR_DEFAULT_ACTIVE
		defaultBtn.Text = "✔  Default (Start/Goal)"
		scenLabel.Text  = "Titik: Default (Start/Goal)"
	else
		defaultBtn.BackgroundColor3 = COLOR_DEFAULT_INACTIVE
		defaultBtn.Text = "Default (Start/Goal)"
		scenLabel.Text  = "Titik: " .. selectedScenario
	end
end

for i, key in ipairs(scenKeys) do
	local pos = scenPositions[i]
